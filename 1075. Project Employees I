2.find the average experience year
  2.1: for same project_id: (3 + 2 + 1) / 3
      code:round(avg(e.experience_years),2) as average_years

#Final Code like 

select p.project_id, round(avg(e.experience_years),2) as average_years
FROM Project p
left join Employee e
on p.employee_id = e.employee_id
group by p.project_id
